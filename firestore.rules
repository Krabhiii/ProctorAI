rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User Profile Rules
    match /users/{userId} {
      function isValidUser(data) {
        return data.email is string &&
               data.coins is number &&
               data.coins >= 0 &&
               data.createdAt == request.time &&
               data.updatedAt == request.time;
      }

      allow get: if isOwner(userId);
      
      allow create: if isOwner(userId) && 
                      isValidUser(incoming()) && 
                      incoming().coins == 300;

      allow update: if isOwner(userId) && (
        // Action: Deduct Coins for Interview
        (incoming().coins == existing().coins - 50 && 
         incoming().diff(existing()).affectedKeys().hasOnly(['coins', 'updatedAt']) &&
         incoming().updatedAt == request.time)
      );
    }

    // Interview Rules
    match /interviews/{interviewId} {
      function isValidInterview(data) {
        return data.userId == request.auth.uid &&
               data.role is string &&
               data.role.size() <= 200 &&
               data.timestamp == request.time;
      }

      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      
      allow create: if isSignedIn() && 
                      isValidInterview(incoming()) &&
                      exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
  }
}
